---
// AboutAndServices.astro
import { useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale || 'es';
const t = useTranslations(lang);
---

<section id="about-and-services" class="w-full bg-white text-bmw-black">
  <!-- Bloque Superior: About (Brand Guidelines Reference) -->
  <div
    class="max-w-[1440px] mx-auto px-6 py-20 lg:py-32 border-b border-[#e5e5e5]"
  >
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-24">
      <!-- Columna Izquierda: Títulos -->
      <div class="md:col-span-4 lg:col-span-5">
        <p
          class="text-bmw-gray font-bold text-sm tracking-widest uppercase mb-4"
        >
          {t('about.subtitle')}
        </p>
        <h2
          class="text-[32px] md:text-[40px] lg:text-[48px] font-bold md:font-medium leading-[1.15] md:leading-[1.10] tracking-tight uppercase"
        >
          {t('about.title')}
        </h2>
      </div>

      <!-- Columna Derecha: Párrafos -->
      <div
        class="md:col-span-8 lg:col-span-7 flex flex-col justify-center max-w-2xl text-[16px] md:text-[18px] leading-[1.30] text-bmw-black font-normal gap-6 space-y-2"
      >
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
      </div>
    </div>
  </div>

  <!-- Bloque Inferior: Services (Contents Reference) -->
  <div class="max-w-[1440px] mx-auto px-6 py-20 lg:py-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-24">
      <!-- Columna Izquierda: Título Principal de Sección -->
      <div class="md:col-span-4 lg:col-span-5">
        <h2
          class="text-[32px] md:text-[40px] lg:text-[48px] font-bold md:font-medium leading-[1.15] tracking-tight"
        >
          {t('services.title')}
        </h2>
      </div>

      <!-- Columna Derecha: Lista de Contenidos -->
      <div class="md:col-span-8 lg:col-span-7 max-w-3xl">
        <div class="flex flex-col gap-12 md:gap-16">
          <!-- Item 01 -->
          <article class="flex flex-col gap-4">
            <h3
              class="text-[20px] md:text-[24px] font-medium leading-[1.20] flex items-baseline gap-3"
            >
              <span class="text-bmw-gray font-light text-[24px] md:text-[28px]"
                >01</span
              >
              {t('services.01.title')}
            </h3>
            <div class="pl-0 sm:pl-[42px] md:pl-[50px] flex flex-col gap-4">
              <p class="text-[16px] leading-[1.30] font-normal text-bmw-black">
                {t('services.01.desc')}
              </p>
              <ul class="list-none flex flex-col gap-2">
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.01.li1')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.01.li2')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.01.li3')}
                </li>
              </ul>
            </div>
          </article>

          <!-- Item 02 -->
          <article class="flex flex-col gap-4">
            <h3
              class="text-[20px] md:text-[24px] font-medium leading-[1.20] flex items-baseline gap-3"
            >
              <span class="text-bmw-gray font-light text-[24px] md:text-[28px]"
                >02</span
              >
              {t('services.02.title')}
            </h3>
            <div class="pl-0 sm:pl-[42px] md:pl-[50px] flex flex-col gap-4">
              <p class="text-[16px] leading-[1.30] font-normal text-bmw-black">
                {t('services.02.desc')}
              </p>
              <ul class="list-none flex flex-col gap-2">
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.02.li1')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.02.li2')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.02.li3')}
                </li>
              </ul>
            </div>
          </article>

          <!-- Item 03 -->
          <article class="flex flex-col gap-4">
            <h3
              class="text-[20px] md:text-[24px] font-medium leading-[1.20] flex items-baseline gap-3"
            >
              <span class="text-bmw-gray font-light text-[24px] md:text-[28px]"
                >03</span
              >
              {t('services.03.title')}
            </h3>
            <div class="pl-0 sm:pl-[42px] md:pl-[50px] flex flex-col gap-4">
              <p class="text-[16px] leading-[1.30] font-normal text-bmw-black">
                {t('services.03.desc')}
              </p>
              <ul class="list-none flex flex-col gap-2">
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.03.li1')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.03.li2')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.03.li3')}
                </li>
              </ul>
            </div>
          </article>

          <article class="flex flex-col gap-4">
            <h3
              class="text-[20px] md:text-[24px] font-medium leading-[1.20] flex items-baseline gap-3"
            >
              <span class="text-bmw-gray font-light text-[24px] md:text-[28px]"
                >04</span
              >
              {t('services.04.title')}
            </h3>
            <div class="pl-0 sm:pl-[42px] md:pl-[50px] flex flex-col gap-4">
              <p class="text-[16px] leading-[1.30] font-normal text-bmw-black">
                {t('services.04.desc')}
              </p>
              <ul class="list-none flex flex-col gap-2">
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.04.li1')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.04.li2')}
                </li>
                <li
                  class="relative text-[15px] text-bmw-gray leading-[1.30] pl-4 before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-bmw-black"
                >
                  {t('services.04.li3')}
                </li>
              </ul>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
