---
// Contact.astro
// Sección de cierre — fondo oscuro, layout centrado editorial (sin formulario)
import { useTranslations } from "../i18n/utils";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang);
---

<section
  id="contact"
  class="w-full bg-[#0a0a0a] text-white border-t border-[#1a1a1a]"
>
  <div class="max-w-[1440px] mx-auto px-6 py-24 lg:py-36">
    <!-- Bloque central -->
    <div class="max-w-2xl mx-auto flex flex-col gap-10">
      <!-- Tagline -->
      <span
        class="text-[13px] font-bold tracking-[0.20em] uppercase text-bmw-blue"
      >
        {t("contact.tagline")}
      </span>

      <!-- Título -->
      <h2
        class="text-[44px] md:text-[56px] lg:text-[72px] font-light leading-[1.05] tracking-tight text-white uppercase"
      >
        {t("contact.title")}
      </h2>

      <!-- Descripción -->
      <p
        class="text-[16px] md:text-[18px] font-normal leading-[1.60] text-[#9a9a9a]"
      >
        {t("contact.desc")}
      </p>

      <!-- CTA principal: botón de email -->
      <a
        href="mailto:zenvik.contact@gmail.com"
        id="contact-email-cta"
        class="group inline-flex items-center gap-3 self-start px-8 py-4 bg-bmw-blue text-white text-[14px] font-bold tracking-[0.10em] uppercase border border-bmw-blue hover:bg-[#0653b6] hover:border-[#0653b6] transition-colors duration-200"
      >
        <span>{t("contact.info.email")}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          class="transition-transform duration-200 group-hover:translate-x-1"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>

      <!-- Separador + info extra -->
      <div
        class="border-t border-[#1f1f1f] pt-8 flex flex-col sm:flex-row gap-8 sm:gap-16"
      >
        <!-- Email clickable -->
        <a
          href="mailto:zenvik.contact@gmail.com"
          id="contact-email-link"
          class="flex items-center gap-4 group"
        >
          <div
            class="w-10 h-10 flex items-center justify-center border border-[#2a2a2a] group-hover:border-bmw-blue transition-colors duration-200"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="square"
              stroke-linejoin="miter"
              class="text-bmw-blue"
            >
              <rect x="2" y="4" width="20" height="16"></rect>
              <polyline points="2,4 12,13 22,4"></polyline>
            </svg>
          </div>
          <span
            class="text-[15px] text-[#cccccc] group-hover:text-white transition-colors duration-200"
          >
            {t("contact.info.email")}
          </span>
        </a>

        <!-- Ubicación -->
        <div class="flex items-center gap-4">
          <div
            class="w-10 h-10 flex items-center justify-center border border-[#2a2a2a]"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="square"
              stroke-linejoin="miter"
              class="text-bmw-blue"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
              ></path>
              <circle cx="12" cy="9" r="2.5"></circle>
            </svg>
          </div>
          <span class="text-[15px] text-[#cccccc]">
            {t("contact.info.location")}
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
