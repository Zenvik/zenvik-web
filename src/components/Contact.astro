---
// Contact.astro
// Sección de contacto — fondo oscuro (#0a0a0a) para cerrar la página con peso visual
// Layout editorial: columna izquierda (copy + info) | columna derecha (formulario)
import { useTranslations } from "../i18n/utils";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang);
---

<section
  id="contact"
  class="w-full bg-[#0a0a0a] text-white border-t border-[#1a1a1a]"
>
  <div class="max-w-[1440px] mx-auto px-6 py-20 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <!-- ── Columna Izquierda: Editorial copy ── -->
      <div class="flex flex-col gap-8 lg:sticky lg:top-32">
        <!-- Tagline -->
        <span
          class="text-[13px] font-bold tracking-[0.20em] uppercase text-bmw-blue"
        >
          {t("contact.tagline")}
        </span>

        <!-- Título principal -->
        <h2
          class="text-[40px] md:text-[52px] lg:text-[64px] font-light leading-[1.10] tracking-tight text-white uppercase"
        >
          {t("contact.title")}
        </h2>

        <!-- Descripción -->
        <p
          class="text-[16px] md:text-[18px] font-normal leading-[1.50] text-[#9a9a9a] max-w-sm"
        >
          {t("contact.desc")}
        </p>

        <!-- Separador -->
        <div class="border-t border-[#1f1f1f] pt-8 flex flex-col gap-5">
          <!-- Email -->
          <a
            href="mailto:zenvik.contact@gmail.com"
            id="contact-email-link"
            class="flex items-center gap-4 group"
          >
            <div
              class="w-10 h-10 flex items-center justify-center border border-[#2a2a2a] group-hover:border-bmw-blue transition-colors duration-200"
            >
              <!-- Mail icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="square"
                stroke-linejoin="miter"
                class="text-bmw-blue"
              >
                <rect x="2" y="4" width="20" height="16"></rect>
                <polyline points="2,4 12,13 22,4"></polyline>
              </svg>
            </div>
            <span
              class="text-[15px] text-[#cccccc] group-hover:text-white transition-colors duration-200"
            >
              {t("contact.info.email")}
            </span>
          </a>

          <!-- Ubicación -->
          <div class="flex items-center gap-4">
            <div
              class="w-10 h-10 flex items-center justify-center border border-[#2a2a2a]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="square"
                stroke-linejoin="miter"
                class="text-bmw-blue"
              >
                <path
                  d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
                ></path>
                <circle cx="12" cy="9" r="2.5"></circle>
              </svg>
            </div>
            <span class="text-[15px] text-[#cccccc]"
              >{t("contact.info.location")}</span
            >
          </div>
        </div>
      </div>

      <!-- ── Columna Derecha: Formulario ── -->
      <div id="contact-form-wrapper">
        <!-- Formulario activo -->
        <form id="contact-form" novalidate class="flex flex-col gap-6">
          <!-- Nombre + Email (2 columnas en desktop) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Nombre -->
            <div class="relative">
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                placeholder=" "
                class="peer w-full bg-transparent border border-[#2a2a2a] text-white text-[15px] px-4 pt-6 pb-3 outline-none focus:border-bmw-blue transition-colors duration-200 placeholder-transparent"
              />
              <label
                for="contact-name"
                class="absolute left-4 top-3 text-[11px] font-bold tracking-[0.12em] uppercase text-[#555555] peer-focus:text-bmw-blue transition-colors duration-200"
              >
                {t("contact.name")}
              </label>
            </div>

            <!-- Email -->
            <div class="relative">
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                placeholder=" "
                class="peer w-full bg-transparent border border-[#2a2a2a] text-white text-[15px] px-4 pt-6 pb-3 outline-none focus:border-bmw-blue transition-colors duration-200 placeholder-transparent"
              />
              <label
                for="contact-email"
                class="absolute left-4 top-3 text-[11px] font-bold tracking-[0.12em] uppercase text-[#555555] peer-focus:text-bmw-blue transition-colors duration-200"
              >
                {t("contact.email")}
              </label>
            </div>
          </div>

          <!-- Empresa -->
          <div class="relative">
            <input
              type="text"
              id="contact-company"
              name="company"
              placeholder=" "
              class="peer w-full bg-transparent border border-[#2a2a2a] text-white text-[15px] px-4 pt-6 pb-3 outline-none focus:border-bmw-blue transition-colors duration-200 placeholder-transparent"
            />
            <label
              for="contact-company"
              class="absolute left-4 top-3 text-[11px] font-bold tracking-[0.12em] uppercase text-[#555555] peer-focus:text-bmw-blue transition-colors duration-200"
            >
              {t("contact.company")}
            </label>
          </div>

          <!-- Servicio de interés -->
          <div class="relative">
            <select
              id="contact-service"
              name="service"
              class="w-full bg-[#0a0a0a] border border-[#2a2a2a] text-[15px] px-4 pt-6 pb-3 outline-none focus:border-bmw-blue transition-colors duration-200 appearance-none cursor-pointer text-[#9a9a9a] focus:text-white"
            >
              <option value="" disabled selected class="text-[#555555]"
                >{t("contact.service.placeholder")}</option
              >
              <option value="web" class="text-white bg-[#111111]"
                >{t("contact.service.01")}</option
              >
              <option value="gps" class="text-white bg-[#111111]"
                >{t("contact.service.02")}</option
              >
              <option value="trazabilidad" class="text-white bg-[#111111]"
                >{t("contact.service.03")}</option
              >
              <option value="ai" class="text-white bg-[#111111]"
                >{t("contact.service.04")}</option
              >
              <option value="other" class="text-white bg-[#111111]"
                >{t("contact.service.other")}</option
              >
            </select>
            <label
              class="absolute left-4 top-3 text-[11px] font-bold tracking-[0.12em] uppercase text-[#555555]"
            >
              {t("contact.service")}
            </label>
            <!-- Chevron personalizado -->
            <div
              class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#555555"
                stroke-width="2"
                stroke-linecap="square"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
          </div>

          <!-- Mensaje -->
          <div class="relative">
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              placeholder=" "
              class="peer w-full bg-transparent border border-[#2a2a2a] text-white text-[15px] px-4 pt-6 pb-3 outline-none focus:border-bmw-blue transition-colors duration-200 resize-none placeholder-transparent"
            ></textarea>
            <label
              for="contact-message"
              class="absolute left-4 top-3 text-[11px] font-bold tracking-[0.12em] uppercase text-[#555555] peer-focus:text-bmw-blue transition-colors duration-200"
            >
              {t("contact.message")}
            </label>
          </div>

          <!-- Botón de envío estilo BMW -->
          <button
            type="submit"
            id="contact-submit"
            class="group relative w-full sm:w-auto sm:self-start flex items-center gap-3 px-8 py-4 bg-bmw-blue text-white text-[14px] font-bold tracking-[0.10em] uppercase border border-bmw-blue hover:bg-[#0653b6] hover:border-[#0653b6] transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="contact-btn-label">{t("contact.send")}</span>
            <!-- Arrow icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="square"
              class="transition-transform duration-200 group-hover:translate-x-1"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </form>

        <!-- Estado de éxito (oculto por defecto) -->
        <div
          id="contact-success"
          class="hidden flex-col items-start gap-6 py-12 border border-[#1f1f1f] px-8"
        >
          <div class="w-12 h-12 flex items-center justify-center bg-bmw-blue">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2.5"
              stroke-linecap="square"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-[24px] font-medium text-white leading-tight">
              {t("contact.success.title")}
            </h3>
            <p class="text-[15px] text-[#9a9a9a] leading-[1.50]">
              {t("contact.success.desc")}
            </p>
          </div>
        </div>
      </div><!-- /contact-form-wrapper -->
    </div>
  </div>
</section>

<script>
  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const submitBtn = document.getElementById(
    "contact-submit",
  ) as HTMLButtonElement | null;
  const btnLabel = document.getElementById("contact-btn-label");
  const successPanel = document.getElementById("contact-success");

  if (form && submitBtn && btnLabel && successPanel) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Validación mínima
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // Estado cargando
      submitBtn.disabled = true;
      const originalLabel = btnLabel.textContent ?? "Enviar mensaje";
      btnLabel.textContent = "Enviando…";

      // Simulación: reemplaza por fetch() a tu backend real
      await new Promise((resolve) => setTimeout(resolve, 1400));

      // Mostrar éxito
      form.style.display = "none";
      successPanel.classList.remove("hidden");
      successPanel.classList.add("flex");
    });
  }
</script>
