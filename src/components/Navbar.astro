---
// Navbar.astro
import { useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale || 'es';
const t = useTranslations(lang);
---

<header class="w-full bg-white z-50 sticky top-0 border-b border-[#e5e5e5]">
  <!-- Fila Superior -->
  <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <!-- Logo Zenvik -->
      <a href={`/${lang === 'es' ? '' : lang + '/'}`} class="relative w-10 h-10 flex items-center justify-center bg-bmw-black text-white hover:opacity-90 transition-opacity">
        <span class="font-bold text-xl uppercase tracking-tighter">Z</span>
      </a>
      <a href={`/${lang === 'es' ? '' : lang + '/'}`} class="font-bold text-2xl tracking-tight uppercase hover:text-bmw-blue transition-colors">Zenvik</a>
    </div>

    <!-- Right Side -->
    <div class="flex items-center gap-8">
      <a href="#contact" class="hidden md:block font-bold text-[16px] hover:text-bmw-blue transition-colors">{t('nav.contact')}</a>
      
      <!-- ES/EN Switch -->
      <div class="flex items-center text-[16px] font-bold border border-[#e5e5e5]">
        <a href="/" class={`px-3 py-1.5 transition-colors ${lang === 'es' ? 'bg-bmw-black text-white' : 'hover:bg-gray-100'}`}>ES</a>
        <a href="/en/" class={`px-3 py-1.5 transition-colors ${lang === 'en' ? 'bg-bmw-black text-white' : 'hover:bg-gray-100'}`}>EN</a>
      </div>
    </div>
  </div>

  <!-- Fila Inferior de Navegación inspirada en la imagen Redo -->
  <div class="border-t border-[#e5e5e5]">
    <nav class="max-w-[1440px] mx-auto px-6 flex flex-wrap items-center justify-between py-3">
      <a href="#about-and-services" class="font-black text-[15px] md:text-[18px] uppercase tracking-wide hover:text-bmw-blue transition-colors flex items-center gap-2">
        {t('nav.services')} <span class="text-bmw-gray text-xs font-normal">01</span>
      </a>
      <a href="#about-and-services" class="font-black text-[15px] md:text-[18px] uppercase tracking-wide hover:text-bmw-blue transition-colors flex items-center gap-2">
        {t('nav.about')} <span class="text-bmw-gray text-xs font-normal">02</span>
      </a>
      <a href="#service-03" class="font-black text-[15px] md:text-[18px] uppercase tracking-wide hover:text-bmw-blue transition-colors flex items-center gap-2 hidden sm:flex">
        {t('nav.trazabilidad')} <span class="text-bmw-gray text-xs font-normal">03</span>
      </a>
      <a href="#service-02" class="font-black text-[15px] md:text-[18px] uppercase tracking-wide hover:text-bmw-blue transition-colors flex items-center gap-2 hidden md:flex">
        {t('nav.monitoreo')} <span class="text-bmw-gray text-xs font-normal">04</span>
      </a>
    </nav>
  </div>
</header>
