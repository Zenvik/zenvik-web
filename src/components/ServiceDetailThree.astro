---
// ServiceFinalTrace.astro
// Layout: Imagen grande izquierda | Texto de impacto derecha (basado en imagen de referencia)
import { useTranslations } from "../i18n/utils";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang);
---

<section
  id="service-trace-final"
  class="w-full bg-white text-bmw-black border-t border-[#e5e5e5]"
>
  <div class="max-w-[1440px] mx-auto px-6 py-20 lg:py-32">
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-16 lg:gap-24 items-start"
    >
      <!-- Columna Izquierda: Imagen Cinemática Alusiva -->
      <div class="w-full overflow-hidden">
        <img
          src="/assets/images/service-trace.png"
          alt="Planta de proceso industrializada - Trazabilidad Zenvik"
          class="w-full h-full object-cover"
          style="aspect-ratio: 4/5;"
        />
      </div>

      <!-- Columna Derecha: Texto de Impacto (al estilo cita editorial de la imagen) -->
      <div class="flex flex-col justify-center h-full pt-10 md:pt-0">
        <!-- Encabezado: "03 Trazabilidad para Plantas de Proceso" (estilo del pantallazo) -->
        <div
          class="flex items-start md:items-baseline gap-4 md:gap-6 flex-col md:flex-row"
        >
          <span
            class="text-[40px] md:text-[50px] lg:text-[60px] font-medium text-bmw-blue leading-none tracking-tighter"
          >
            03
          </span>
          <h2
            class="text-[32px] md:text-[40px] lg:text-[48px] font-medium leading-[1.10] tracking-tight"
          >
            {t("services.03.title")}
          </h2>
        </div>

        <!-- Párrafo de impacto grande (al estilo de la cita "I was skeptical...") -->
        <p
          class="text-[22px] md:text-[28px] lg:text-[34px] font-light leading-[1.30] tracking-tight text-[#262626] mb-10 md:mb-14"
        >
          "Herramienta integral para capturar, controlar y visualizar en tiempo
          real la información de animales y productos en cada etapa del proceso,
          fortaleciendo la trazabilidad y el control operativo."
        </p>

        <!-- Atribución bifurcada: nombre en negro, rol en BMW Blue -->
        <div class="flex flex-col gap-1 border-t border-[#e5e5e5] pt-6">
          <span
            class="text-[15px] font-bold tracking-wide uppercase text-bmw-black"
          >
            Trazabilidad para Plantas de Proceso
          </span>
          <span
            class="text-[13px] font-bold tracking-widest uppercase text-bmw-blue font-mono"
          >
            03 — Servicio Zenvik
          </span>
        </div>

        <!-- Detalle de características debajo (bullets cuadrados BMW) -->
        <ul class="list-none flex flex-col gap-4 mt-10 md:mt-14 max-w-lg">
          <li
            class="relative text-[15px] md:text-[16px] text-bmw-black leading-[1.30] pl-6 before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-2 before:h-2 before:bg-bmw-blue"
          >
            Plantas de beneficio, desposte y acondicionamiento
          </li>
          <li
            class="relative text-[15px] md:text-[16px] text-bmw-black leading-[1.30] pl-6 before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-2 before:h-2 before:bg-bmw-blue"
          >
            Soporte multiespecie: bovino, porcino, caprino, ovino, avícola y más
          </li>
          <li
            class="relative text-[15px] md:text-[16px] text-bmw-black leading-[1.30] pl-6 before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-2 before:h-2 before:bg-bmw-blue"
          >
            Interfaz web o desktop simple, intuitiva y adaptable
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
