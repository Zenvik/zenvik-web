---
// ServiceDetailTwo.astro
import { useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale || 'es';
const t = useTranslations(lang);
---

<section id="service-02" class="w-full bg-white text-bmw-black">
  <div class="max-w-[1440px] mx-auto px-6 pb-20 lg:pb-32">
    
    <!-- Bloque Superior: Header Text -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 lg:gap-24 mb-16 lg:mb-24 pt-20 border-t border-[#e5e5e5]">
      
      <!-- Columna Izquierda: Número y Título -->
      <div class="md:col-span-4 lg:col-span-5 flex flex-col md:flex-row items-start gap-4 md:gap-6">
        <span class="text-[40px] md:text-[48px] lg:text-[56px] font-medium text-bmw-blue leading-none tracking-tighter">
          02
        </span>
        <h2 class="text-[32px] md:text-[40px] lg:text-[48px] font-medium leading-[1.10] tracking-tight">
          {t('services.02.title')}
        </h2>
      </div>

      <!-- Columna Derecha: Párrafo -->
      <div class="md:col-span-8 lg:col-span-7 flex flex-col justify-start">
        <p class="text-[16px] md:text-[18px] leading-[1.30] lg:leading-[1.40] font-normal max-w-2xl text-[#262626]">
          {t('services.02.desc')}
        </p>
      </div>
      
    </div>

    <!-- Bloque Inferior: Typographic Poster (Lienzo Gris) -->
    <div class="w-full bg-[#f4f4f4] py-24 sm:py-32 md:py-40 flex flex-col items-center justify-center text-center px-4 overflow-hidden border border-[#e5e5e5]">
      <!-- Arte Tipográfico BMW Style (Variación extrema de pesos de fuente) -->
      <div class="flex flex-col items-center justify-center -space-y-2 md:-space-y-4 lg:-space-y-6">
        
        <span class="text-[28px] sm:text-[44px] md:text-[56px] lg:text-[76px] font-light text-bmw-blue uppercase tracking-tight leading-none z-10 transition-transform hover:scale-105 duration-500">
          {t('services.02.poster1')}
        </span>
        
        <span class="text-[36px] sm:text-[56px] md:text-[72px] lg:text-[96px] font-black text-bmw-black uppercase tracking-tighter leading-[0.85] z-20 transition-transform hover:scale-105 duration-500">
          {t('services.02.poster2')}
        </span>
        
        <span class="text-[24px] sm:text-[36px] md:text-[48px] lg:text-[64px] font-normal text-bmw-gray uppercase tracking-normal leading-none z-10 pt-4 md:pt-6 transition-transform hover:scale-105 duration-500">
          {t('services.02.poster3')}
        </span>
        
      </div>
    </div>

  </div>
</section>
