---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = Astro.currentLocale || 'es';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Zenvik | Soluciones Digitales" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Usaremos Inter de Google Fonts para asimilar la estructura tipográfica de la marca -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="font-sans antialiased text-bmw-black mx-auto overflow-x-hidden min-h-screen">
    <slot />
  </body>
</html>
